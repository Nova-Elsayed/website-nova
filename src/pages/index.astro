---
import Base from "@/layouts/Base.astro";
import {
  getLandingPage,
  getWorkshops,
  getSinglePage,
} from "@/lib/API";
import WorkshopsList from "@/partials/WorkshopsList.astro";
import ArticlesList from "@/partials/ArticlesList.astro";
import RichTextContainer from "@/components/RichTextContainer.astro";
import SectionHeader from "@/partials/SectionHeader.astro";
import Button from "@/components/Button.astro";
import Section from "@/partials/Section.astro";
import PaperBackground from "@/partials/PaperBackground.astro";
import ContentError from "@/components/ContentError.astro";

export const prerender = true;

let page, sessionsPage, workshopsPage, workshops, upcomingWorkshops;
let error = false;

try {
  page = await getLandingPage();
  sessionsPage = await getSinglePage("4UgguPWhfkrumrdwMIeAsL");
  workshopsPage = await getSinglePage("2BOI94KBfNnnUXkZCIq9rN");
  workshops = await getWorkshops();

  workshops.sort((a, b) =>
    Date.parse(b.props.dateStart) - Date.parse(a.props.dateStart)
  );

  const today = new Date();
  upcomingWorkshops = workshops.filter(
    (item) => new Date(item.props.dateStart) >= today
  );
} catch (e) {
  error = true;
}
---

<Base title={page?.headerHeadline} meta_title={page?.headerHeadline}>
  {error ? <ContentError message="Die Seite konnte nicht geladen werden. Bitte versuche es später erneut." /> : <>
  <!-- HEADER -->
  <section
    class="relative w-screen min-h-screen px-8 lg:px-16 pt-8 md:pt-24  md:overflow-visible z-20"
  >
    <div class="relative">
      {
        page.headerImage?.fields.file.url && (
          <img
            class="h-auto w-96 md:w-1/2 -mb-24 md:-mb-36 lg:-mb-56 xl:-mb-72 2xl:-mb-96 z-0 mx-auto"
            src={page.headerImage.fields.file.url}
            alt={page.headerImage.fields.description || ""}
            loading="lazy"
          />
        )
      }
      <div class="relative w-80 mx-auto ">
        <h1 class="text-2xl optical-md text-stone-600 text-right">
          <img
            class="h-36 lg:h-44 ms-auto me-0"
            src="/images/NovaElSayed-Script.png"
            alt={page.headerHeadline}
            fetchpriority="high"
          />
          <span class="italic text-red-400">{page.headerSubHeadline}</span>
        </h1>
        <div class="flex justify-end md:justify-end mt-4">
          <Button
            className="me-4"
            label={page.headerLink01Label}
            href={page.headerLink01URL}
          />
          <Button label={page.headerLink02Label} href={page.headerLink02URL} />
        </div>
      </div>
    </div>
  </section>
  <!-- /HEADER -->
  <div>
    <!-- MAIN CONTENT -->
    <!-- INTRO -->
    <Section>
      <PaperBackground>
        <SectionHeader
          title={page.introHeadline}
          subtitle={page.introSubHeadline}
        />
        <RichTextContainer class="text-left" content={page.introText} />
      </PaperBackground>
      <div class="flex w-full link-bar mt-8">
        <Button
          label={page.introLinkLabel ? page.introLinkLabel : "Erfahre mehr …"}
          href={page.introLinkURL}
          className="mx-auto"
        />
      </div>
    </Section>
    <!-- / INTRO -->
    <!-- WORKSHOPS -->

    <Section id="workshops">
      <SectionHeader title={page.workshopsHeadline} />
      <div class="sm:grid grid-cols-3 gap-4 mx-auto mb-8 max-w-prose">
        {
          workshopsPage.image && (
            <img
              class="col-span-1 h-auto w-full "
              src={workshopsPage.image.fields.file.url}
              alt={workshopsPage.image.fields.description || "Workshop Bild"}
              loading="lazy"
            />
          )
        }
        <RichTextContainer
          class="text-left col-span-2"
          content={workshopsPage.introText}
        />
      </div>
      {
        upcomingWorkshops && upcomingWorkshops.length > 0 && (
          <div id="upcoming-workshops" class="mt-16">
            <h3
              set:html="Meine nächsten Workshops"
              class="mb-4 text-2xl optical-md"
            />
            <WorkshopsList workshops={upcomingWorkshops} />
          </div>
        )
      }

      <div class="flex w-full link-bar mt-8">
        <Button
          label="Erfahre mehr …"
          href={`/${workshopsPage.slug}`}
          className="mx-auto"
        />
      </div>
    </Section>
    <!-- / WORKSHOPS -->

    <!-- SESSIONS -->

    <Section>
      <SectionHeader title={page.sessionsHeadline} />
      <RichTextContainer class="text-left" content={sessionsPage.introText} />
      <div class="flex w-full link-bar mt-8">
        <Button
          label="Erfahre mehr …"
          href={`/${sessionsPage.slug}`}
          className="mx-auto"
        />
      </div>
    </Section>

    <!-- / SESSIONS -->

    <!-- ARTICLES -->

    <Section>
      <SectionHeader title={page.articlesHeadline} />
      <RichTextContainer
        class="mb-16 text-left"
        content={page.articlesIntroText}
      />

      <ArticlesList onlyFeatured={true} />

      <div class="flex w-full link-bar mt-8">
        <Button
          label={page.articlesLinkLabel}
          href={page.articlesLinkURL}
          className="mx-auto"
        />
      </div>
    </Section>
    <!-- / ARTICLES -->
  </div>
  </>}
</Base>
